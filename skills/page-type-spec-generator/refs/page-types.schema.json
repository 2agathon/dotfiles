{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/medical-material-taxonomy.schema.json",
  "title": "Medical Material Taxonomy",
  "description": "材料页内容分类与类型定义（两级树结构），用于对每页材料进行 type 标注并按 category 聚合检索。Schema 仅约束结构与字段语义，不强制枚举所有类型值。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "description",
    "last_updated",
    "categories"
  ],
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema 载荷版本（语义化版本 SemVer）",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "last_updated": {
      "type": "string",
      "description": "最近更新日期（ISO 8601 date）",
      "format": "date"
    },
    "schema_meta": {
      "type": "object",
      "description": "Schema 元信息（可选）",
      "additionalProperties": false,
      "properties": {
        "owner": { "type": "string" },
        "maintainers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "change_log": {
          "type": "array",
          "items": { "$ref": "#/$defs/ChangeLogEntry" }
        }
      }
    },
    "sources": {
      "type": "array",
      "description": "规范依据与参考来源（可选，用于追溯）",
      "items": { "$ref": "#/$defs/SourceRef" },
      "uniqueItems": true
    },
    "categories": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/Category" }
    }
  },
  "$defs": {
    "ID": {
      "type": "string",
      "description": "稳定 ID（建议全大写 + 下划线）。例如 CATEGORY_RESULTS_REPORTS, TYPE_INPATIENT_ADMISSION_RECORD",
      "pattern": "^[A-Z][A-Z0-9_]*$",
      "minLength": 3,
      "maxLength": 128
    },
    "HumanName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "SourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "title", "authority_level"],
      "properties": {
        "key": {
          "type": "string",
          "description": "来源 key（在 type/category 的 source_keys 中引用）",
          "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._-]{1,63}$"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        "authority_level": {
          "type": "string",
          "description": "权威等级（用于冲突裁决与优先级）",
          "enum": ["NATIONAL_STANDARD", "INDUSTRY_STANDARD", "REGULATORY_NORM", "TEXTBOOK", "HOSPITAL_TEMPLATE", "OTHER"]
        },
        "publisher": { "type": "string" },
        "year": {
          "type": "integer",
          "minimum": 1900,
          "maximum": 2100
        },
        "doc_number": {
          "type": "string",
          "description": "标准号/文件号（如 WS 445.* 或卫生部/卫健委规范性文件编号）"
        },
        "effective_date": {
          "type": "string",
          "format": "date"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "notes": { "type": "string" }
      }
    },
    "ChangeLogEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["date", "summary"],
      "properties": {
        "date": { "type": "string", "format": "date" },
        "summary": { "type": "string", "minLength": 1 },
        "details": { "type": "string" }
      }
    },
    "Category": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "description", "types"],
      "properties": {
        "id": { "$ref": "#/$defs/ID" },
        "name": { "$ref": "#/$defs/HumanName" },
        "description": { "type": "string", "minLength": 1 },
        "order": {
          "type": "integer",
          "description": "展示排序（可选）",
          "minimum": 0
        },
        "deprecated": {
          "type": "boolean",
          "default": false
        },
        "replaced_by": {
          "description": "若 deprecated=true，则指向替代 category id",
          "$ref": "#/$defs/ID"
        },
        "source_keys": {
          "type": "array",
          "description": "本 category 的规范依据（可选，引用顶层 sources[].key）",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "types": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/Type" }
        }
      }
    },
    "Type": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name"],
      "properties": {
        "id": { "$ref": "#/$defs/ID" },
        "name": { "$ref": "#/$defs/HumanName" },
        "description": {
          "type": "string",
          "description": "类型解释：定义边界、与相近类型的区分点（建议写）"
        },
        "aliases": {
          "type": "array",
          "description": "常见别名/院内口径差异/历史叫法（可选）",
          "items": { "type": "string", "minLength": 1, "maxLength": 256 },
          "uniqueItems": true
        },
        "deprecated": {
          "type": "boolean",
          "default": false
        },
        "replaced_by": {
          "description": "若 deprecated=true，则指向替代 type id",
          "$ref": "#/$defs/ID"
        },
        "source_keys": {
          "type": "array",
          "description": "本 type 的规范依据（可选，引用顶层 sources[].key）",
          "items": { "type": "string" },
          "uniqueItems": true
        }
      }
    }
  }
}
