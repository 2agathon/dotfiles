{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://welleval-plus/schema/medical-material.page-type-block-spec.review.json",
  "title": "Medical Material Page-Type Block Review Schema",
  "type": "object",
  "required": ["version", "page_type", "block_types", "tags", "action_paths"],
  "additionalProperties": false,
  "properties": {
    "version": { "$ref": "#/$defs/VisibleString" },
    "page_type": {
      "type": "object",
      "required": ["id", "name"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^(?:TYPE_[A-Z0-9_]+|TYPE_PLACEHOLDER_[A-Z0-9_]+)$"
        },
        "name": { "$ref": "#/$defs/VisibleString" }
      }
    },
    "action_paths": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["context", "phase", "action", "block_type_ids"],
        "additionalProperties": false,
        "properties": {
          "context": { "$ref": "#/$defs/IdName" },
          "phase": { "$ref": "#/$defs/IdName" },
          "action": { "$ref": "#/$defs/IdName" },
          "block_type_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^(?:BLOCK_[A-Z0-9_]+|BLOCK_PLACEHOLDER_[A-Z0-9_]+)$"
            }
          }
        }
      }
    },
    "block_types": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "description", "tags"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^(?:BLOCK_[A-Z0-9_]+|BLOCK_PLACEHOLDER_[A-Z0-9_]+)$"
          },
          "name": { "$ref": "#/$defs/VisibleString" },
          "description": { "$ref": "#/$defs/VisibleString" },
          "tags": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["tag_id"],
              "additionalProperties": false,
              "properties": {
                "tag_id": {
                  "type": "string",
                  "pattern": "^(?:TAG_[A-Z0-9_]+|TAG_PLACEHOLDER_[A-Z0-9_]+)$"
                },
                "role": { "$ref": "#/$defs/VisibleString" },
                "description": { "$ref": "#/$defs/VisibleString" }
              }
            }
          }
        }
      }
    },
    "tags": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "required": ["id", "name", "value_hint", "context_hint"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^(?:TAG_[A-Z0-9_]+|TAG_PLACEHOLDER_[A-Z0-9_]+)$"
          },
          "name": { "$ref": "#/$defs/VisibleString" },
          "value_hint": { "$ref": "#/$defs/VisibleString" },
          "context_hint": { "$ref": "#/$defs/VisibleString" },
          "anchor_binding": {
            "oneOf": [
              { "$ref": "#/$defs/AnchorBinding" },
              { "$ref": "#/$defs/PendingObject" }
            ]
          }
        }
      }
    }
  },
  "$defs": {
    "PendingString": {
      "type": "string",
      "const": "__PTSG_PENDING__"
    },
    "VisibleString": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        { "$ref": "#/$defs/PendingString" }
      ]
    },
    "PendingObject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["placeholder"],
      "properties": {
        "placeholder": { "$ref": "#/$defs/PendingString" }
      }
    },
    "IdName": {
      "type": "object",
      "required": ["id", "name"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/VisibleString" },
        "name": { "$ref": "#/$defs/VisibleString" }
      }
    },
    "AnchorBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_tag_ids", "page_window", "direction", "required"],
      "properties": {
        "target_tag_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^(?:TAG_[A-Z0-9_]+|TAG_PLACEHOLDER_[A-Z0-9_]+)$"
          }
        },
        "page_window": {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode"],
          "properties": {
            "mode": {
              "oneOf": [
                { "type": "string", "enum": ["within_type_run", "bounded"] },
                { "$ref": "#/$defs/PendingString" }
              ]
            },
            "prev": {
              "oneOf": [
                { "type": "integer", "minimum": 0 },
                { "$ref": "#/$defs/PendingString" }
              ]
            },
            "next": {
              "oneOf": [
                { "type": "integer", "minimum": 0 },
                { "$ref": "#/$defs/PendingString" }
              ]
            }
          }
        },
        "direction": {
          "oneOf": [
            { "type": "string", "enum": ["before", "after", "same_segment", "nearby"] },
            { "$ref": "#/$defs/PendingString" }
          ]
        },
        "required": {
          "oneOf": [
            { "type": "boolean" },
            { "$ref": "#/$defs/PendingString" }
          ]
        },
        "self_resolution": {
          "oneOf": [
            { "type": "string", "enum": ["self_only", "self_first", "direction_first", "direction_only"] },
            { "$ref": "#/$defs/PendingString" }
          ]
        }
      }
    }
  }
}
