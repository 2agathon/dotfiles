{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/medical-material-taxonomy.review.schema.json",
  "title": "Medical Material Taxonomy Review Schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "description", "last_updated", "categories"],
  "properties": {
    "version": { "$ref": "#/$defs/VisibleString" },
    "description": { "$ref": "#/$defs/VisibleString" },
    "last_updated": { "$ref": "#/$defs/VisibleString" },
    "schema_meta": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "owner": { "$ref": "#/$defs/VisibleString" },
        "maintainers": {
          "type": "array",
          "items": { "$ref": "#/$defs/VisibleString" }
        },
        "change_log": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["date", "summary"],
            "properties": {
              "date": { "$ref": "#/$defs/VisibleString" },
              "summary": { "$ref": "#/$defs/VisibleString" },
              "details": { "$ref": "#/$defs/VisibleString" }
            }
          }
        }
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key", "title", "authority_level"],
        "properties": {
          "key": { "$ref": "#/$defs/VisibleString" },
          "title": { "$ref": "#/$defs/VisibleString" },
          "authority_level": { "$ref": "#/$defs/VisibleString" },
          "publisher": { "$ref": "#/$defs/VisibleString" },
          "year": {
            "oneOf": [
              { "type": "integer", "minimum": 1900, "maximum": 2100 },
              { "$ref": "#/$defs/PendingString" }
            ]
          },
          "doc_number": { "$ref": "#/$defs/VisibleString" },
          "effective_date": { "$ref": "#/$defs/VisibleString" },
          "url": { "$ref": "#/$defs/VisibleString" },
          "notes": { "$ref": "#/$defs/VisibleString" }
        }
      }
    },
    "categories": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/Category" }
    }
  },
  "$defs": {
    "PendingString": {
      "type": "string",
      "const": "__PTSG_PENDING__"
    },
    "VisibleString": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        { "$ref": "#/$defs/PendingString" }
      ]
    },
    "ID": {
      "type": "string",
      "pattern": "^(?:[A-Z][A-Z0-9_]*|(?:CATEGORY|TYPE)_PLACEHOLDER_[A-Z0-9_]+)$",
      "minLength": 3,
      "maxLength": 128
    },
    "Category": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "description", "types"],
      "properties": {
        "id": { "$ref": "#/$defs/ID" },
        "name": { "$ref": "#/$defs/VisibleString" },
        "description": { "$ref": "#/$defs/VisibleString" },
        "order": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "$ref": "#/$defs/PendingString" }
          ]
        },
        "deprecated": {
          "oneOf": [
            { "type": "boolean" },
            { "$ref": "#/$defs/PendingString" }
          ]
        },
        "replaced_by": { "$ref": "#/$defs/VisibleString" },
        "source_keys": {
          "type": "array",
          "items": { "$ref": "#/$defs/VisibleString" }
        },
        "types": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/Type" }
        }
      }
    },
    "Type": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "description"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^(?:[A-Z][A-Z0-9_]*|TYPE_PLACEHOLDER_[A-Z0-9_]+)$"
        },
        "name": { "$ref": "#/$defs/VisibleString" },
        "description": { "$ref": "#/$defs/VisibleString" },
        "aliases": {
          "type": "array",
          "items": { "$ref": "#/$defs/VisibleString" }
        },
        "deprecated": {
          "oneOf": [
            { "type": "boolean" },
            { "$ref": "#/$defs/PendingString" }
          ]
        },
        "replaced_by": { "$ref": "#/$defs/VisibleString" },
        "source_keys": {
          "type": "array",
          "items": { "$ref": "#/$defs/VisibleString" }
        }
      }
    }
  }
}
